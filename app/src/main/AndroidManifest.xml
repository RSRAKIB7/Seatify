<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name="SmartHostelApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Seatify">

        <!-- Splash Activity -->
        <activity
            android:name="activities.SplashActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- Login Activity -->
        <activity
            android:name="activities.LoginActivity"
            android:exported="true"
            android:launchMode="singleTop" />

        <!-- Register Activity (Google OAuth Deep Link) -->
        <activity
            android:name="activities.RegisterActivity"
            android:exported="true"
            android:launchMode="singleTop">

            <intent-filter android:label="register-callback">

                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:scheme="seatify"
                    android:host="activity_register" />

            </intent-filter>

        </activity>

        <!-- Reset Password Activity -->
        <activity
            android:name="activities.ResetPasswordActivity"
            android:exported="true"
            android:launchMode="singleTop">

            <intent-filter android:label="reset-password">

                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:scheme="seatify"
                    android:host="activity_reset_password" />

            </intent-filter>

        </activity>

        <!-- Main App Activities -->

        <activity
            android:name="activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="seatify" android:host="activity_main" />
            </intent-filter>
        </activity>

        <activity
            android:name="activities.AdminActivity"
            android:exported="false" />

        <activity
            android:name="activities.PropertyDetailActivity"
            android:exported="false" />

        <activity
            android:name="activities.SearchActivity"
            android:exported="false" />

        <activity
            android:name="activities.BookingActivity"
            android:exported="false" />

        <activity
            android:name="activities.AddPropertyActivity"
            android:exported="false" />

        <activity
            android:name="activities.MyPropertiesActivity"
            android:exported="false" />

        <activity
            android:name="activities.MyProfileActivity"
            android:exported="false" />

        <activity
            android:name="activities.AboutUsActivity"
            android:exported="false" />

        <activity
            android:name="activities.BookingDetailActivity"
            android:exported="false" />

        <activity
            android:name="activities.SettingsActivity"
            android:exported="false" />

        <activity
            android:name="activities.ChangePasswordActivity"
            android:exported="false" />

        <activity
            android:name="activities.MyInformationActivity"
            android:exported="false" />

        <activity
            android:name="activities.ManageBookingsActivity"
            android:exported="false" />

        <!-- Google Maps API -->

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="YOUR_GOOGLE_MAPS_API_KEY" />

    </application>

</manifest>