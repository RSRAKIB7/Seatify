<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_change_password"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Change Password"
            app:navigationIcon="@drawable/ic_search"
            app:titleTextColor="@color/text_dark" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Update Your Security"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="24dp"/>

        <!-- Old Password -->
        <EditText
            android:id="@+id/et_old_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Current Password"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp" />

        <!-- New Password -->
        <EditText
            android:id="@+id/et_new_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:hint="New Password"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Confirm New Password -->
        <EditText
            android:id="@+id/et_confirm_new_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Confirm New Password"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btn_save_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Change Password"
            android:backgroundTint="@color/primary_start"
            android:textColor="@color/white" />

        <ProgressBar
            android:id="@+id/pb_change_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

    </LinearLayout>
</LinearLayout>
