<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_booking_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Complete Your Booking"
            android:textColor="@color/text_dark"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_property_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/tv_booking_title">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_social_button">

                <ImageView
                    android:id="@+id/iv_booking_property_image"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Property Image"
                    android:src="@drawable/bg_gradient" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_booking_property_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Property Name"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_booking_property_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="৳ 0,000 / month"
                        android:textColor="@color/primary_start"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Seat Selection -->
        <TextView
            android:id="@+id/tv_label_seat_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Number of Seats to Book"
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_property_summary" />

        <LinearLayout
            android:id="@+id/layout_seat_selection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_label_seat_count">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_minus_seat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_social_button"
                android:text="-"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tv_booking_seat_count"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_plus_seat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_social_button"
                android:text="+"
                android:textSize="20sp" />
        </LinearLayout>

        <!-- 1. Verification & Identity -->
        <TextView
            android:id="@+id/tv_section_identity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="1. Verification &amp; Identity"
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/layout_seat_selection"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/et_booking_user_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Full Name"
            android:inputType="textPersonName"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_section_identity" />

        <EditText
            android:id="@+id/et_booking_nid"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_text"
            android:hint="NID / Birth Certificate Number"
            android:inputType="number"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/et_booking_user_name" />

        <TextView
            android:id="@+id/tv_label_id_photo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Institutional / Work ID Card Photo"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/et_booking_nid"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_id_card_photo"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/input_stroke"
            app:layout_constraintTop_toBottomOf="@id/tv_label_id_photo">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/iv_id_card_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:contentDescription="ID Card Preview"
                    android:src="@drawable/ic_add"
                    app:tint="@color/text_gray" />
                <ProgressBar
                    android:id="@+id/pb_id_card"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <EditText
            android:id="@+id/et_booking_guardian"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Parent's / Guardian's Name"
            android:inputType="textPersonName"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/cv_id_card_photo" />

        <!-- 2. Contact & Emergency -->
        <TextView
            android:id="@+id/tv_section_emergency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="2. Contact &amp; Emergency"
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/et_booking_guardian"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/et_booking_permanent_address"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Permanent Address"
            android:inputType="textPostalAddress"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_section_emergency" />

        <EditText
            android:id="@+id/et_booking_emergency_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Emergency Contact Name"
            android:inputType="textPersonName"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/et_booking_permanent_address" />

        <LinearLayout
            android:id="@+id/layout_emergency_relation"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/et_booking_emergency_name">
            <EditText
                android:id="@+id/et_booking_emergency_relation"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_edit_text"
                android:hint="Relationship"
                android:paddingHorizontal="12dp" />
            <EditText
                android:id="@+id/et_booking_emergency_phone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_edit_text"
                android:hint="Emergency Phone"
                android:inputType="phone"
                android:paddingHorizontal="12dp" />
        </LinearLayout>

        <!-- 3. Booking Details -->
        <TextView
            android:id="@+id/tv_section_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="3. Booking Details"
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/layout_emergency_relation"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/et_move_in_date"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_text"
            android:drawableStart="@drawable/ic_calendar"
            android:drawablePadding="8dp"
            android:focusable="false"
            android:hint="Target Move-in Date"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_section_details" />

        <EditText
            android:id="@+id/et_booking_duration"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Expected Stay Duration"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/et_move_in_date" />

        <EditText
            android:id="@+id/et_booking_workplace"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_text"
            android:hint="University / Company Name"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/et_booking_duration" />

        <!-- 4. Preferences -->
        <TextView
            android:id="@+id/tv_section_prefs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="4. Preferences"
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/et_booking_workplace"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/layout_prefs_row1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tv_section_prefs">
            <Spinner
                android:id="@+id/spinner_booking_gender"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/bg_edit_text" />
            <Spinner
                android:id="@+id/spinner_smoking"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_edit_text" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_booking_dietary"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Dietary Preference"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/layout_prefs_row1" />

        <EditText
            android:id="@+id/et_booking_notes"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edit_text"
            android:gravity="top"
            android:hint="Any other special requirements..."
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/et_booking_dietary" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_confirm_booking"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_gradient"
            android:text="Confirm Booking Request"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/et_booking_notes"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
