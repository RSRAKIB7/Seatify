<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit My Information"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="24dp"/>

        <!-- Profile Photo -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_profile_photo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="60dp"
            app:strokeColor="@color/primary_start"
            app:strokeWidth="2dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/iv_profile_info"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person"
                    app:tint="@color/text_gray" />

                <ProgressBar
                    android:id="@+id/pb_profile_photo"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_logo_circle"
                    android:backgroundTint="@color/primary_start"
                    android:padding="6dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/white" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Full Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textColor="@color/text_gray" />
        <EditText
            android:id="@+id/et_info_name"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/text_dark"
            android:inputType="textPersonName" />

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Address (Locked)"
            android:textColor="@color/text_gray" />
        <EditText
            android:id="@+id/et_info_email"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:enabled="false"
            android:textColor="@color/text_gray" />

        <!-- Phone Number -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:textColor="@color/text_gray" />
        <EditText
            android:id="@+id/et_info_phone"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/text_dark"
            android:inputType="phone" />

        <!-- Gender -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gender"
            android:textColor="@color/text_gray" />
        <Spinner
            android:id="@+id/spinner_gender"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:layout_marginBottom="16dp"
            android:entries="@array/gender_options" />

        <!-- Occupation / Institution -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Occupation / Institution Name"
            android:textColor="@color/text_gray" />
        <EditText
            android:id="@+id/et_info_occupation"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/text_dark"
            android:hint="e.g. Student, University, or Office" />

        <!-- Present Address -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Present Address / Village / Town"
            android:textColor="@color/text_gray" />
        <EditText
            android:id="@+id/et_info_present_address"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/text_dark" />

        <!-- Permanent Address -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Permanent Address"
            android:textColor="@color/text_gray" />
        <EditText
            android:id="@+id/et_info_permanent_address"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/text_dark" />

        <!-- NID / Birth Cert -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NID / Birth Certificate Number"
            android:textColor="@color/text_gray" />
        <EditText
            android:id="@+id/et_info_nid"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/text_dark"
            android:inputType="number" />

        <!-- Emergency Contact Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Contact Name"
            android:textColor="@color/text_gray" />
        <EditText
            android:id="@+id/et_info_emergency_name"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/text_dark" />

        <!-- Emergency Contact Phone -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Contact Phone"
            android:textColor="@color/text_gray" />
        <EditText
            android:id="@+id/et_info_emergency_phone"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edit_text"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/text_dark"
            android:inputType="phone" />

        <Button
            android:id="@+id/btn_save_info"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save All Changes"
            android:backgroundTint="@color/primary_start"
            android:textColor="@color/white"
            android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>
